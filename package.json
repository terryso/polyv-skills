{
  "name": "polyv-skills",
  "version": "1.0.0",
  "description": "PolyV 直播平台 API Skills 集合，为 Claude Code 提供与保利威直播平台交互的能力。",
  "main": "tools/clis/polyv.js",
  "bin": {
    "polyv": "./tools/clis/polyv.js"
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "mocha 'tests/unit/*.test.js'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "config-test": "node tools/clis/polyv.js config-test"
  },
  "keywords": [
    "polyv",
    "live-streaming",
    "claude-code",
    "skills",
    "api"
  ],
  "author": "terryso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/terryso/polyv-skills.git"
  },
  "bugs": {
    "url": "https://github.com/terryso/polyv-skills/issues"
  },
  "homepage": "https://github.com/terryso/polyv-skills#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
